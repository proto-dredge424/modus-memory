<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.enclave.modus.go</string>

	<key>ProgramArguments</key>
	<array>
		<string>/bin/zsh</string>
		<string>/Users/modus/modus/scripts/modus-start.sh</string>
	</array>

	<key>WorkingDirectory</key>
	<string>/Users/modus/modus</string>

	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/Users/modus/.local/bin</string>
		<key>HOME</key>
		<string>/Users/modus</string>
	</dict>

	<key>KeepAlive</key>
	<true/>

	<key>ThrottleInterval</key>
	<integer>10</integer>

	<key>StandardOutPath</key>
	<string>/Users/modus/modus/data/modus-go-stdout.log</string>

	<key>StandardErrorPath</key>
	<string>/Users/modus/modus/data/modus-go-stderr.log</string>

	<key>RunAtLoad</key>
	<true/>
</dict>
</plist>
